{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker Compose Up",
      "type": "shell",
      "command": "docker compose up -d --build",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin;C:\\Program Files\\nodejs;C:\\Users\\User\\AppData\\Roaming\\npm;${env:PATH}" }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Container",
          "endsPattern": "Started|Running|Healthy"
        }
      },
      "presentation": { "group": "docker", "reveal": "always" }
    },
    {
      "label": "Docker Compose Down",
      "type": "shell",
      "command": "docker compose down",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin;C:\\Program Files\\nodejs;C:\\Users\\User\\AppData\\Roaming\\npm;${env:PATH}" }
      },
      "presentation": { "group": "docker", "reveal": "always" }
    },
    {
      "label": "Backend — Local",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": { "PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin;C:\\Program Files\\nodejs;C:\\Users\\User\\AppData\\Roaming\\npm;${env:PATH}" }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "INFO:.*Uvicorn running",
          "endsPattern": "INFO:.*Application startup complete"
        }
      },
      "presentation": { "group": "servers", "reveal": "always" }
    },
    {
      "label": "Frontend",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend",
        "env": { "PATH": "C:\\Program Files\\Docker\\Docker\\resources\\bin;C:\\Program Files\\nodejs;C:\\Users\\User\\AppData\\Roaming\\npm;${env:PATH}" }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "group": "servers", "reveal": "always" }
    }
  ]
}
